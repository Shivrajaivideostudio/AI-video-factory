# Python Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environments
.env
.venv
env/
venv/
ENV/

# AI Video Factory Outputs (Large Files)
# Niche di gayi line 'static/outputs/' folder ke andar sab kuch ignore kar degi.
static/outputs/

# Upar wali line ke karan, 'static/outputs' folder bhi ignore ho jayega.
# Isliye, folder ko Git mein rakhne ke liye .gitkeep file ko un-ignore karein.
!static/outputs/.gitkeep

# Logs & Temp Files
*.log
temp/
.pytest_cache/

# OS-specific files
.DS_Store
Thumbs.db
